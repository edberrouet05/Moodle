<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris_clair"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Carte info générale -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txt_sigle_cours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/couleur_primaire"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_titre_cours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/texte_principal"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/txt_enseignant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/texte_secondaire"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/txt_session"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/texte_secondaire"
                    android:layout_marginTop="2dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Carte description -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/texte_principal" />

                <TextView
                    android:id="@+id/txt_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/texte_secondaire"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Carte annonces -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_annonces"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/titre_annonces"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/texte_principal" />

                <LinearLayout
                    android:id="@+id/ll_annonces_cours"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Boutons navigation -->
        <Button
            android:id="@+id/btn_voir_travaux"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titre_travaux"
            android:backgroundTint="@color/couleur_primaire"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/btn_voir_quiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titre_quiz"
            android:backgroundTint="@color/couleur_secondaire"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
