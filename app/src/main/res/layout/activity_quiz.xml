<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanc"
    android:padding="16dp">

    <TextView
        android:id="@+id/txt_progression"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/texte_secondaire"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/txt_enonce"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="@color/texte_principal"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/txt_progression"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp" />

    <RadioGroup
        android:id="@+id/radio_group_choix"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/txt_enonce"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp">

        <RadioButton
            android:id="@+id/radio_choix_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:paddingVertical="8dp" />

        <RadioButton
            android:id="@+id/radio_choix_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:paddingVertical="8dp" />

        <RadioButton
            android:id="@+id/radio_choix_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:paddingVertical="8dp" />

        <RadioButton
            android:id="@+id/radio_choix_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:paddingVertical="8dp" />

    </RadioGroup>

    <Button
        android:id="@+id/btn_suivant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_suivant"
        android:backgroundTint="@color/couleur_primaire"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
