<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanc"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Logo cercle M -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_cercle_primaire">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="M"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/blanc" />
        </FrameLayout>

        <!-- Nom de l'app -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="Mini Moodle"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/couleur_primaire" />

        <!-- Titre section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Connexion"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/texte_principal" />

        <!-- Sous-titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Accède à tes cours et travaux"
            android:textSize="14sp"
            android:textColor="@color/texte_secondaire" />

        <!-- Champ courriel -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_courriel"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:hint="Courriel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/champ_courriel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Champ mot de passe -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_mot_de_passe"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Mot de passe"
            app:passwordToggleEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/champ_mot_de_passe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Mot de passe oublié -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:text="Mot de passe oublié?"
            android:textColor="@color/couleur_primaire"
            android:textSize="13sp"
            android:padding="4dp" />

        <!-- Bouton connexion -->
        <Button
            android:id="@+id/btn_connexion"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/couleur_primaire"
            android:text="Se connecter"
            android:textSize="16sp" />

        <!-- Lien inscription -->
        <TextView
            android:id="@+id/lien_inscription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:padding="8dp"
            android:text="Pas encore de compte ? S'inscrire"
            android:textColor="@color/couleur_primaire"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
