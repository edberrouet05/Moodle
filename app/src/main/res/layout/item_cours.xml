<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/blanc">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Barre accent gauche -->
        <View
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:minHeight="70dp"
            android:background="@color/couleur_primaire" />

        <!-- Contenu -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/txt_sigle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/couleur_primaire" />

            <TextView
                android:id="@+id/txt_titre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/texte_principal"
                android:layout_marginTop="2dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txt_credits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/texte_secondaire"
                android:layout_marginTop="3dp" />

        </LinearLayout>

        <!-- Badge statut -->
        <TextView
            android:id="@+id/txt_statut_cours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_chip_vert"
            android:text="@string/statut_cours_actif"
            android:textColor="@color/blanc"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
