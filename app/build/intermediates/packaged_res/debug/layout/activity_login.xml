<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanc"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32dp">

        <TextView
            android:id="@+id/txt_titre_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/couleur_primaire"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="64dp" />

        <TextView
            android:id="@+id/txt_sous_titre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connexion"
            android:textSize="18sp"
            android:textColor="@color/texte_secondaire"
            app:layout_constraintTop_toBottomOf="@id/txt_titre_app"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_courriel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_courriel"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:layout_constraintTop_toBottomOf="@id/txt_sous_titre"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="48dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/champ_courriel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_mot_de_passe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_mot_de_passe"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:passwordToggleEnabled="true"
            app:layout_constraintTop_toBottomOf="@id/layout_courriel"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/champ_mot_de_passe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btn_connexion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_connexion"
            android:backgroundTint="@color/couleur_primaire"
            app:layout_constraintTop_toBottomOf="@id/layout_mot_de_passe"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/lien_inscription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lien_inscription"
            android:textColor="@color/couleur_primaire"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/btn_connexion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
